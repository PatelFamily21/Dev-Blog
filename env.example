# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed to version control.

# Django secret key — generate a new one at https://djecrety.ir/
SECRET_KEY=your-secret-key-here

# Set to True for local development, False for production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS = dev-blog-a74q.onrender.com

# Leave blank to use SQLite locally.
# On Render this is set automatically from the connected database.
DATABASE_URL=
